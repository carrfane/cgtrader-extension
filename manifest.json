{
  "manifest_version": 3,
  "name": "CGTrader Visual Search for TurboSquid",
  "version": "0.1.1",
  "description": "Adds a 'Search on CGTrader' button to TurboSquid product pages to find visually similar 3D models on CGTrader.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["tabs"],
  "host_permissions": [
    "https://www.cgtrader.com/*",
    "https://p.turbosquid.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.turbosquid.com/3d-models/*",
        "https://www.turbosquid.com/*/3d-models/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
